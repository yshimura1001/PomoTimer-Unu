<UserControl x:Class="PomoTimer.TimeTableTimerButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PomoTimer"
             mc:Ignorable="d">
    <Grid>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,0,0,0">
            <ToggleButton Name="TopmostToggle" 
                      Content="前" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" 
                      Command="{Binding ChangeTopMostCommand}"
                      Margin="4,0,0,0"/>
            <ToggleButton Name="DarkModeToggle" 
                      Content="ダ" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" 
                      Command="{Binding DarkModeCommand}"
                      Margin="0,0,0,0"/>
            <Button Content="設" Command="{Binding ShowConfigWindowCommand}" Margin="0,0,0,0"/>
            <Button Content="休" Command="{Binding ShowBreakTimerWindowCommand}" Margin="0,0,0,0"/>
            <Button Content="切" Command="{Binding ModeChangeCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
