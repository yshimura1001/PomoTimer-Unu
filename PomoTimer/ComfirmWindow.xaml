<Window x:Class="PomoTimer.ComfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PomoTimer"
        mc:Ignorable="d"
        Topmost="True" ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="{Binding AppTitleStr}" Height="450" Width="800">
    <Grid>
        <!-- レイアウト行定義：上にタイトル、中央に3ボタン行、下に「閉じる」 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- タイトル -->
            <RowDefinition Height="48"/>
            <!-- タイトル下の余白（見出しとボタン間） -->
            <RowDefinition Height="Auto"/>
            <!-- 3ボタン -->
            <RowDefinition Height="36"/>
            <!-- 3ボタンと閉じるの間の余白 -->
            <RowDefinition Height="Auto"/>
            <!-- 閉じる -->
            <RowDefinition/>
            <!-- 余白 -->
        </Grid.RowDefinitions>

        <!-- ページ左右の余白を確保するためのコンテナ -->
        <Grid Margin="160,40,160,0" Grid.RowSpan="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- タイトル（太字・大きめ） -->
            <TextBlock Grid.Row="0"
                       Text="{Binding AppTitleStr}"
                       FontFamily="Segoe UI"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#111"
                       Margin="0,0,0,0"
                       TextWrapping="NoWrap"/>

            <!-- 3つのボタン（横並び） -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,24,0,0">
                <Button x:Name="BtnOpenTimetable"
                        Content="時刻表タイプで開く"
                        Command="{Binding ShowTimeTableTimerWindowCommand}"
                        Width="140" Height="32"
                        Margin="0,0,16,0"/>
                <Button x:Name="BtnOpenVariable"
                        Content="変動タイプで開く"
                        Command="{Binding ShowVariableTimerWindowCommand}"
                        Width="140" Height="32"
                        Margin="0,0,16,0"/>
                <Button x:Name="BtnOpenFixed"
                        Content="固定タイプで開く"
                        Command="{Binding ShowFixedTimerWindowCommand}"
                        Width="140" Height="32"/>
            </StackPanel>

            <!-- 閉じる（3ボタンの下、中央寄せ） -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="170,24,0,0">
                <!-- 左から3ボタンの中央寄せ位置をざっくり再現するために Margin を調整 -->
                <Button x:Name="BtnClose"
                        Content="閉じる" Command="{Binding ForceQuitCommand}"
                        Width="72" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
