<Window x:Class="PomoTimer.BreakTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PomoTimer"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        AllowsTransparency="False">

    <!-- 画面全体を大まかに3行構成：上部メニュー / 本文 / 下部 -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ======= 上部：左「強制終了」・右「保存しないで閉じる」 ======= -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="強制終了"
                    Padding="16,8"
                    Margin="0,0,16,0"
                    FontSize="50"
                    Height="100"
                    Command="{Binding ForceQuitCommand}"/>

            <Button Grid.Column="2"
                    Content="保存しないで閉じる"
                    Padding="16,8"
                    FontSize="50"
                    Height="100"
                    Command="{Binding CloseWithoutSaveCommand}"/>
        </Grid>

        <!-- ======= 本文：中央の大きな表示 ======= -->
        <!-- Viewboxで中身をスケーリングし、どの解像度でもバランス良く見せる -->
        <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="Both">
            <!-- デザイン基準サイズ（適当な仮想座標） -->
            <Grid Width="1600" Height="800">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <!-- 見出し「休憩中」と右の大ボックス -->
                    <RowDefinition Height="0.8*"/>
                    <!-- 残り時間 -->
                    <RowDefinition Height="0.8*"/>
                    <!-- 現在時刻 -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="780"/>
                    <!-- 左のラベル列 -->
                    <ColumnDefinition Width="820"/>
                    <!-- 右の値ボックス列 -->
                </Grid.ColumnDefinitions>

                <!-- 1行目：左 -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="休憩中"
                           FontSize="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- 1行目：右 -->
                <Border Grid.Row="0" Grid.Column="1"
                        BorderBrush="#FFCCCCCC"
                        BorderThickness="3"
                        CornerRadius="4"
                        Padding="24"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimeFrameStr, FallbackValue=時間枠名}"
                               FontSize="100"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 2行目：左 -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="残り時間"
                           FontSize="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- 2行目：右 -->
                <Border Grid.Row="1" Grid.Column="1"
                        BorderBrush="#FFCCCCCC"
                        BorderThickness="3"
                        CornerRadius="4"
                        Padding="24"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding RestTimeStr, FallbackValue=HH:MM}"
                               FontSize="120"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 3行目：左 -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="現在時刻"
                           FontSize="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <!-- 3行目：右 -->
                <Border Grid.Row="2" Grid.Column="1"
                        BorderBrush="#FFCCCCCC"
                        BorderThickness="3"
                        CornerRadius="4"
                        Padding="24"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding NowTimeStr, FallbackValue=HH:MM}"
                               FontSize="120"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Viewbox>

        <!-- ======= 下部：右下「閉じる」ボタン ======= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="閉じる"
                    Padding="28,12"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Right"
                    FontSize="50"
                    Height="100"
                    Command="{Binding CloseCommand}"/>
        </Grid>
    </Grid>
</Window>

